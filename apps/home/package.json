{
  "name": "home",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "cf-build": "opennextjs-cloudflare build",
    "cf-check": "wrangler check",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "node -e \"if (!process.env.INVOICE_APP_ORIGIN) { console.error('INVOICE_APP_ORIGIN is required to deploy apps/home on Cloudflare.'); process.exit(1); }\" && opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.1"
  }
}
