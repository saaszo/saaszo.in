{
  "name": "saaszo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "cf:build:home": "npm run cf-build --workspace=home",
    "cf:build:invoice": "npm run cf-build --workspace=invoice",
    "cf:check:home": "npm run cf-check --workspace=home",
    "cf:check:invoice": "npm run cf-check --workspace=invoice",
    "cf:preview:home": "npm run preview --workspace=home",
    "cf:preview:invoice": "npm run preview --workspace=invoice",
    "cf:deploy:home": "npm run deploy --workspace=home",
    "cf:deploy:invoice": "npm run deploy --workspace=invoice",
    "cf:typegen:home": "npm run cf-typegen --workspace=home",
    "cf:typegen:invoice": "npm run cf-typegen --workspace=invoice"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "firebase": "^11.9.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "prettier": "^3.7.4",
    "tailwindcss": "^4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2",
    "wrangler": "^4.83.0"
  },
  "engines": {
    "node": ">=24.x.x"
  },
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "apps/*"
  ]
}
